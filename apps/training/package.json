{
  "name": "training",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "check-types": "tsc --noEmit",
    "train:initial": "tsx src/scripts/train-model.ts --mode=initial",
    "train:incremental": "tsx src/scripts/train-model.ts --mode=incremental",
    "train": "tsx src/scripts/train-model.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@repo/schemas": "*",
    "@tensorflow/tfjs": "^4.20.0",
    "@tensorflow/tfjs-node": "^4.20.0",
    "dotenv": "^17.2.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  }
}
