    "db:seed:real": "tsx src/infra/database/drizzle/seed-realistic.ts",
    "db:seed:all": "npm run db:seed && npm run db:seed:real",
    "migrate:dev": "drizzle-kit generate && drizzle-kit migrate"
  },
